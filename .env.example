# Polymarket API (public, no key needed)
POLYMARKET_API_BASE=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE=https://clob.polymarket.com
POLYMARKET_SUBGRAPH=https://api.thegraph.com/subgraphs/name/polymarket/matic-markets

# Detection thresholds
WHALE_TRADE_USD=5000          # Flag trades above this USD value
RAPID_ODDS_SHIFT_PCT=8        # % probability move to flag
RAPID_ODDS_WINDOW_MIN=5       # Time window (minutes) for rapid odds detection
ORDERBOOK_IMBALANCE_RATIO=3.0 # Bid/ask imbalance multiplier to flag
INSIDER_SCORE_ALERT=60        # Alert when score >= this

# Alerts (optional - leave blank to disable)
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Server
HOST=0.0.0.0
PORT=8000
POLL_INTERVAL=10   # seconds between market polls
